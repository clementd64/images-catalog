{
  "id": "codex",
  "version": "1.0.0",
  "name": "Codex CLI",
  "mounts": [
    {
      "source": "${localEnv:HOME}/.codex",
      "target": "/home/vscode/.codex",
      "type": "bind"
    }
  ],
  "securityOpt": [
    "seccomp=unconfined",
    "apparmor=unconfined"
  ],
  "options": {
    "version": {
      "type": "string",
      "default": "latest",
      "description": "GitHub release tag to install. Use \"latest\" for the newest release."
    }
  }
}
